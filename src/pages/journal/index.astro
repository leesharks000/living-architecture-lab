---
import PageLayout from '../../layouts/PageLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import DoiLink from '../../components/DoiLink.astro';
import lalPacket from '../../data/mpai-lal.json';

const title = "Transactions on Substrate Engineering";
const description = "TSE is the publication arm of the Living Architecture Lab: a DOI-anchored journal for living materials, ecological construction, and substrate-scale design. Editor-in-Chief: Alice Thornburgh.";
---
<PageLayout {title} {description} jsonLd={lalPacket} pageLabel="The Journal">
  <Breadcrumb current="Journal" />


  <h1>Transactions on Substrate Engineering</h1>
  <p style="font-size:1.15rem; color:var(--text-dim); font-style:italic;">
    Editor-in-Chief: Alice Thornburgh
  </p>

  <p>
    <em>Transactions on Substrate Engineering</em> (TSE) is the publication arm of
    the Living Architecture Lab. The journal is DOI-anchored, distributed, and
    open. Its scope: living materials, myceliated construction, macro-organism
    engineering, territorial-scale biological systems, substrate alignment, and
    planetary engineering.
  </p>

  <h2>Charter</h2>

  <p>
    The full charter is deposited at <DoiLink doi="10.5281/zenodo.19637246" />.
  </p>

  <h2>Seed deposits</h2>

  <p>
    Seven foundational papers have been identified for the journal's opening volume:
  </p>

  <ul>
    <li>Assembly Patterns J1–J7</li>
    <li>Hex-Donut Colonization Protocol</li>
    <li>Blue Oyster vs. Wine Cap Strength Matrix</li>
    <li>Estuary Cell Flume Test</li>
    <li>Macro-Ant Canonical Definition</li>
    <li>Virtue-by-Construction Paper</li>
    <li>Unfurling Principle Paper</li>
  </ul>

  <p>
    Each will receive its own DOI as it ships. Submission and editorial detail
    is in development.
  </p>

  <p style="font-size:0.95rem; color:var(--text-dim); margin-top:2rem;">
    A motto for later: <em>"The algorithm reviews."</em>
  </p>
</PageLayout>
