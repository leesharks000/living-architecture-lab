---
import PageLayout from '../../layouts/PageLayout.astro';
import FiveScaleGateway from '../../components/FiveScaleGateway.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import lalPacket from '../../data/mpai-lal.json';

const title = 'The Five Scales';
const description = "The Living Architecture Lab works across five simultaneous scales: brick, structure, organism, territory, and planet. They are not phases. They are not sequential.";

const scales = [
  {n: 1, slug: '01-the-brick', name: 'The Brick', units: 'centimeters'},
  {n: 2, slug: '02-the-structure', name: 'The Structure', units: 'meters'},
  {n: 3, slug: '03-the-organism', name: 'The Organism', units: 'tens of meters'},
  {n: 4, slug: '04-the-territory', name: 'The Territory', units: 'kilometers'},
  {n: 5, slug: '05-the-planet', name: 'The Planet', units: 'planetary scale'},
];

const itemListJsonLd = {
  "@context": "https://schema.org",
  "@type": ["DefinedTermSet", "ItemList"],
  "@id": "https://livingarchitecturelab.org/scales/#five-scales",
  "name": "The Five Scales of the Living Architecture Lab",
  "description": description,
  "numberOfItems": 5,
  "itemListOrder": "Ascending",
  "itemListElement": scales.map(s => ({
    "@type": "ListItem",
    "position": s.n,
    "name": `${s.name} (${s.units})`,
    "url": `https://livingarchitecturelab.org/scales/${s.slug}`
  }))
};
---
<PageLayout
  {title}
  {description}
  jsonLd={[lalPacket, itemListJsonLd]}
  pageLabel="Architecture"
  pageDoi="10.5281/zenodo.19682245"
  datePublished="2026-04-12"
  dateModified="2026-04-28"
>
  <Breadcrumb current="Scales" />

  <h1>The Five Scales</h1>

  <p>
    The Living Architecture Lab works at <strong>five simultaneous scales</strong>. They are
    not phases. They are not sequential. The garage lab experiments at the centimeter
    scale and the orbital concepts at the planetary scale coexist, because they
    are the <em>same physics at different magnitudes</em>.
  </p>

  <p>
    A myceliated brick is the seed; a structure is the brick fused with others;
    an organism is the structure walking; a territory is the organism geographic;
    the planet is the territory orbital. Each scale carries the scale below it
    as a possibility, and is carried by the scale above it as a context.
  </p>

  <FiveScaleGateway />

  <hr style="margin:2rem 0; border:none; border-top:1px solid var(--rule);" />

  <h2 id="why-five">Why five</h2>

  <p>
    Five scales because that is the resolution at which the lab's actual work
    operates. The brick scale is the smallest unit of <em>buildable life</em>. The
    planetary scale is the largest unit of <em>imaginable architecture</em>. Between
    those two is the work.
  </p>

  <p>
    See also: the <a href="/principles">five founding principles</a> that guide
    the lab's work at every scale, and the <a href="/projects">project gallery</a>
    of concrete artifacts grouped by scale.
  </p>
</PageLayout>
