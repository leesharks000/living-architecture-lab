---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  jsonLd?: object | object[];
  canonical?: string;
  pageLabel?: string;
  author?: string;
  authorOrcid?: string;
  sims?: string[];
  pageDoi?: string;
  pageOrcid?: string;
  datePublished?: string;
  dateModified?: string;
}

const props = Astro.props;
const { pageLabel, ...baseProps } = props;
---
<BaseLayout {...baseProps}>
  <article>
    {pageLabel && <p class="specimen-label">{pageLabel}</p>}
    <slot />
  </article>
</BaseLayout>
