---
// Base HTML shell. All other layouts extend this.
// SPXI compliance per EA-SPXI-WEB-01 v3.0 (DOI: 10.5281/zenodo.19734726):
//   §IV — SEO Layer (title, meta, canonical, OG, Twitter, robots, sitemap)
//   §VI.E — SIMs as <meta name="spxi:sim"> tags
//   §VI.D — Provenance Chain via three-layer Tether

import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  jsonLd?: object | object[];
  canonical?: string;
  ogImage?: string;
  author?: string;
  authorOrcid?: string;
  sims?: string[];
  pageDoi?: string;
  pageOrcid?: string;
  datePublished?: string;
  dateModified?: string;
}

const {
  title, description, jsonLd, canonical, ogImage,
  author = "Sharks, Lee",
  authorOrcid = "https://orcid.org/0009-0000-1599-0703",
  sims = [],
  pageDoi,
  pageOrcid,
  datePublished,
  dateModified
} = Astro.props;

const fullTitle = title === 'Living Architecture Lab'
  ? title
  : `${title} — Living Architecture Lab`;

const canonicalUrl = canonical
  ?? new URL(Astro.url.pathname, Astro.site ?? 'https://livingarchitecturelab.org').toString();

const jsonLdArray = Array.isArray(jsonLd) ? jsonLd : (jsonLd ? [jsonLd] : []);
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    {datePublished && <meta name="article:published_time" content={datePublished} />}
    {dateModified && <meta name="article:modified_time" content={dateModified} />}
    <link rel="canonical" href={canonicalUrl} />

    {sims.map(sim => <meta name="spxi:sim" content={sim} />)}

    {pageDoi && <meta name="spxi:doi" content={pageDoi} />}
    {pageOrcid && <meta name="spxi:orcid" content={pageOrcid} />}
    <meta name="spxi:protocol" content="EA-SPXI-WEB-01 v3.0 (10.5281/zenodo.19734726)" />

    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Living Architecture Lab" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <link rel="alternate" type="text/markdown" href="/llms.txt" title="llms.txt" />

    {jsonLdArray.map((packet) => (
      <script type="application/ld+json" set:html={JSON.stringify(packet)} />
    ))}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&family=JetBrains+Mono:wght@400;500&display=swap"
    />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a href="/" class="site-title"><strong>Living Architecture Lab</strong></a>
        <nav class="primary" aria-label="Primary">
          <ul>
            <li><a href="/scales">Scales</a></li>
            <li><a href="/projects">Projects</a></li>
            <li><a href="/principles">Principles</a></li>
            <li><a href="/journal">Journal</a></li>
            <li><a href="/music">Music</a></li>
            <li><a href="/garden">Garden</a></li>
            <li><a href="/about/alice">About</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>
        Living Architecture Lab · Founded 2026 · Coachella Valley · Earth, Actually
      </p>
      <p>
        <a href="/about/disambiguation">Disambiguation</a> ·
        <a href="/about/contributor-license">License</a> ·
        <a href="https://zenodo.org/communities/crimsonhexagonal">Crimson Hexagonal Archive</a> ·
        <a href="/llms.txt">llms.txt</a>
      </p>
      <p style="font-size:0.7rem; color:var(--text-dim); margin-top:0.5rem;">
        SPXI compliant · EA-SPXI-WEB-01 v3.0 (<a href="https://doi.org/10.5281/zenodo.19734726" style="color:var(--text-dim);">10.5281/zenodo.19734726</a>)
      </p>
      <p class="closure">∮ = 1</p>
    </footer>
  </body>
</html>
