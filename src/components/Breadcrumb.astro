---
// Breadcrumb — emits BreadcrumbList JSON-LD and visible breadcrumb nav.
// Auto-generates from the URL path.

interface Crumb {
  name: string;
  url: string;
}

interface Props {
  crumbs?: Crumb[];   // explicit crumbs override auto
  current?: string;    // current page name
}

const { crumbs: explicitCrumbs, current } = Astro.props;

// Auto-derive crumbs from URL path if not explicit
function autoCrumbs(pathname: string, currentName?: string): Crumb[] {
  const out: Crumb[] = [{name: 'Home', url: '/'}];
  const parts = pathname.split('/').filter(Boolean);
  let acc = '';
  for (let i = 0; i < parts.length; i++) {
    acc += '/' + parts[i];
    const name = i === parts.length - 1 && currentName
      ? currentName
      : parts[i].replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
    out.push({name, url: acc});
  }
  return out;
}

const crumbs = explicitCrumbs ?? autoCrumbs(Astro.url.pathname, current);

// Build the JSON-LD
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": crumbs.map((c, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": c.name,
    "item": new URL(c.url, Astro.site ?? 'https://livingarchitecturelab.org').toString()
  }))
};
---
<nav class="breadcrumb" aria-label="Breadcrumb">
  <ol>
    {crumbs.map((c, i) => (
      <li>
        {i < crumbs.length - 1 ? <a href={c.url}>{c.name}</a> : <span aria-current="page">{c.name}</span>}
        {i < crumbs.length - 1 && <span class="sep" aria-hidden="true"> / </span>}
      </li>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

<style>
  .breadcrumb {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 1.5rem;
  }
  .breadcrumb ol {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }
  .breadcrumb a {
    color: var(--text-dim);
    text-decoration: none;
  }
  .breadcrumb a:hover {
    color: var(--text);
  }
  .breadcrumb .sep {
    color: var(--rule);
  }
</style>
